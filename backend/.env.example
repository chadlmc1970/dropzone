# .env.example
DATABASE_URL=postgresql://user:password@host:5432/dbname
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=https://dropzone.onrender.com/callback
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_AUDIENCE=https://dropzone-api.onrender.com
FRONTEND_URL=https://dropzone.onrender.com
SECRET_KEY=generate-random-256-bit-key
CORS_ORIGINS=https://dropzone.onrender.com
